local AutoCollectConnection = nil
local CurrentTarget = nil

local function FindBullEssence()
    for _, item in ipairs(workspace.Items:GetChildren()) do
        if item.Name == "Bull's essence" and item:FindFirstChild("HumanoidRootPart") or item:FindFirstChildWhichIsA("BasePart") then
            return item
        end
    end
    return nil
end

local function StartAutoCollect()
    if AutoCollectConnection then return end

    AutoCollectConnection = game:GetService("RunService").Heartbeat:Connect(function()
        local character = game.Players.LocalPlayer.Character
        if not character or not character:FindFirstChild("HumanoidRootPart") then return end

        local root = character.HumanoidRootPart

        -- Kalau sedang di target dan target masih ada
        if CurrentTarget and CurrentTarget.Parent then
            local targetRoot = CurrentTarget:FindFirstChild("HumanoidRootPart") or CurrentTarget:FindFirstChildWhichIsA("BasePart")
            if targetRoot then
                root.CFrame = targetRoot.CFrame + Vector3.new(0, 5, 0)  -- TP ke atas item
                return
            end
        end

        -- Cari target baru kalau target lama sudah hilang
        local newTarget = FindBullEssence()
        if newTarget then
            CurrentTarget = newTarget
            local targetRoot = newTarget:FindFirstChild("HumanoidRootPart") or newTarget:FindFirstChildWhichIsA("BasePart")
            if targetRoot then
                root.CFrame = targetRoot.CFrame + Vector3.new(0, 5, 0)
            end
        end
    end)
end

local function StopAutoCollect()
    if AutoCollectConnection then
        AutoCollectConnection:Disconnect()
        AutoCollectConnection = nil
    end
    CurrentTarget = nil
end

